# Streamlit Cloud → App settings → Secrets
#
# ВАЖНО: НЕ кладите сюда ANTHROPIC_API_KEY если деплой публичный —
# иначе все посетители будут жечь ваш баланс. Вместо этого каждый посетитель
# вводит свой ключ через UI (поле «🔑 Anthropic API key»).
#
# Если деплой приватный (только вы) — можно положить:
#   ANTHROPIC_API_KEY = "sk-ant-..."
#   ANTHROPIC_MODEL = "claude-haiku-4-5-20251001"

# ОБЯЗАТЕЛЬНОЕ поле — email-идентификация для SEC EDGAR API.
# Без него EDGAR блокирует запросы.
SEC_USER_AGENT = "Your Name your.email@example.com"
